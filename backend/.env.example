# =============================================================================
# Legal Knowledge Graph RAG — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values before running the application.
# Never commit .env to version control (it's in .gitignore).
#
# Required to set before first run:
#   - NEO4J_PASSWORD (or change the default in docker-compose.yml)
#   - At least one LLM key: OPENAI_API_KEY or ANTHROPIC_API_KEY
#
# All other values have sensible defaults for local development.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
# ENVIRONMENT=production  # Set in production — tightens CORS and enables auth guards


# -----------------------------------------------------------------------------
# Neo4j (matches docker-compose.yml defaults)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=testpassword123
# NEO4J_DATABASE=          # Leave blank to use the default database


# -----------------------------------------------------------------------------
# Qdrant (matches docker-compose.yml defaults)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=          # Required for Qdrant Cloud; leave blank for local


# -----------------------------------------------------------------------------
# PostgreSQL (matches docker-compose.yml defaults)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:testpassword123@localhost:5432/legal_data


# -----------------------------------------------------------------------------
# LLM — Primary (OpenAI-compatible)
# -----------------------------------------------------------------------------
# Standard OpenAI:
OPENAI_API_KEY=sk-...

# NVIDIA NIM (high-reasoning models):
# OPENAI_API_KEY=nvapi-...
# BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_MODEL=openai/gpt-oss-120b

# LiteLLM proxy or other OpenAI-compatible endpoints:
# OPENAI_BASE_URL=http://localhost:4000

# Default model when OPENAI_MODEL is not set:
LLM_MODEL=gpt-4o-mini


# -----------------------------------------------------------------------------
# LLM — Anthropic (alternative / fallback)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...


# -----------------------------------------------------------------------------
# LLM — Google Gemini (alternative / fallback)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=AIza...


# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
# Local SentenceTransformer model (no API key needed):
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# For higher-quality embeddings (larger, slower):
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# EMBEDDING_DIMENSION=1024


# -----------------------------------------------------------------------------
# Data directories
# -----------------------------------------------------------------------------
# Relative to backend/ directory, or use an absolute path:
DATA_DIR=../data


# -----------------------------------------------------------------------------
# Ingestion pipeline tuning
# -----------------------------------------------------------------------------
# Number of legal units per DB batch during graph/vector loading:
INGESTION_BATCH_SIZE=50

# Seconds to wait between HTTP requests (polite rate limiting for source sites):
INGESTION_RATE_LIMIT_SLEEP=1.0


# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Set to false to disable LLM concept extraction (reduces cost, only uses regex):
ENABLE_LLM_CONCEPT_EXTRACTION=true

# Set to false if APOC plugin is NOT installed on Neo4j:
ENABLE_APOC=true


# -----------------------------------------------------------------------------
# Admin API (production security)
# -----------------------------------------------------------------------------
# Set this to protect admin endpoints in production:
# ADMIN_API_KEY=your-secret-admin-key
